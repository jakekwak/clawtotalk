# ClawToTalk Configuration
# Copy this file to .env and fill in your values

# === Required API Keys ===

# OpenAI API Key (for Whisper speech-to-text)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic API Key (for Claude)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ElevenLabs API Key (for text-to-speech)
# Get one at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ElevenLabs Voice ID
# Find voice IDs at: https://elevenlabs.io/voice-library
# Default "River" voice: SAz9YHcvj6GT2YYXdXww
ELEVENLABS_VOICE_ID=SAz9YHcvj6GT2YYXdXww

# === Server Configuration ===

# Port to run the server on
PORT=3333

# === Bot Personality ===

# Name of your AI assistant (displayed in UI)
BOT_NAME=Gerty

# System prompt - customize the bot's personality
# Keep it concise for voice interactions
BOT_SYSTEM_PROMPT=You are a friendly and capable AI assistant. You're speaking via voice, so keep responses conversational and concise. Don't use markdown or formatting - just natural speech. Keep responses brief unless asked for detail.
