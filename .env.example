# ClawToTalk Configuration
# Copy this file to .env and fill in your values

# === Required API Keys ===

# OpenAI API Key (for Whisper speech-to-text)
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ElevenLabs API Key (for text-to-speech)
# Get one at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# ElevenLabs Voice ID
# Find voice IDs at: https://elevenlabs.io/voice-library
# Default "River" voice: SAz9YHcvj6GT2YYXdXww
ELEVENLABS_VOICE_ID=SAz9YHcvj6GT2YYXdXww

# === Mode Selection ===

# Set to 'true' to route through OpenClaw (requires OpenClaw installed)
# Set to 'false' to use direct Claude API calls
USE_OPENCLAW=false

# === OpenClaw Mode (when USE_OPENCLAW=true) ===
# Session ID for voice conversations (maintains context)
VOICE_SESSION_ID=voice-clawtotalk

# === Direct Claude Mode (when USE_OPENCLAW=false) ===
# Anthropic API Key (only needed if USE_OPENCLAW=false)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# === Server Configuration ===

# Port to run the server on
PORT=3333

# === Bot Personality ===

# Name of your AI assistant (displayed in UI)
BOT_NAME=Assistant

# System prompt for direct Claude mode (ignored in OpenClaw mode)
BOT_SYSTEM_PROMPT=You are a friendly AI assistant. Keep responses conversational and concise for voice. Don't use markdown or formatting.
