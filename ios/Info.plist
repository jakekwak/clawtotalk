<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Information -->
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    
    <key>CFBundleDisplayName</key>
    <string>Voice Assistant</string>
    
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    
    <key>CFBundleVersion</key>
    <string>1</string>
    
    <!-- Minimum iOS Version -->
    <key>MinimumOSVersion</key>
    <string>14.0</string>
    
    <!-- Device Capabilities -->
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
        <string>microphone</string>
    </array>
    
    <!-- Privacy Permissions -->
    
    <!-- Microphone Permission (REQUIRED) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>This app needs access to your microphone to record voice messages for the AI assistant. Your voice recordings are sent to the server for speech-to-text conversion and AI processing.</string>
    
    <!-- Speech Recognition Permission (Optional but recommended) -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>This app uses speech recognition to convert your voice to text for better interaction with the AI assistant.</string>
    
    <!-- Local Network Permission (for Tailscale/local server) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>This app needs access to your local network to connect to your voice assistant server via Tailscale or local network.</string>
    
    <!-- Bonjour Services (for local network discovery) -->
    <key>NSBonjourServices</key>
    <array>
        <string>_http._tcp</string>
        <string>_https._tcp</string>
    </array>
    
    <!-- Background Modes -->
    <key>UIBackgroundModes</key>
    <array>
        <!-- Audio playback and recording in background -->
        <string>audio</string>
        <!-- Background fetch for server communication -->
        <string>fetch</string>
        <!-- Remote notifications (optional) -->
        <string>remote-notification</string>
    </array>
    
    <!-- Audio Session Configuration -->
    <key>UIRequiresPersistentWiFi</key>
    <false/>
    
    <!-- App Transport Security -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Allow HTTP for local network connections -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
        <!-- For development/testing with local servers -->
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <!-- Exception domains for specific servers -->
        <key>NSExceptionDomains</key>
        <dict>
            <!-- Example: Allow HTTP for Tailscale IPs -->
            <key>localhost</key>
            <dict>
                <key>NSExceptionAllowsInsecureHTTPLoads</key>
                <true/>
                <key>NSIncludesSubdomains</key>
                <true/>
            </dict>
        </dict>
    </dict>
    
    <!-- Supported Interface Orientations (iPhone) -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <!-- Supported Interface Orientations (iPad) -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    
    <!-- Launch Screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    
    <!-- Status Bar -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleDefault</string>
    
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    
    <!-- Scene Configuration (iOS 13+) -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
        <key>UISceneConfigurations</key>
        <dict>
            <key>UIWindowSceneSessionRoleApplication</key>
            <array>
                <dict>
                    <key>UISceneConfigurationName</key>
                    <string>Default Configuration</string>
                    <key>UISceneDelegateClassName</key>
                    <string>SceneDelegate</string>
                </dict>
            </array>
        </dict>
    </dict>
    
    <!-- Battery Optimization -->
    <!-- Prevent excessive battery drain -->
    <key>UIApplicationExitsOnSuspend</key>
    <false/>
    
    <!-- App Icon -->
    <key>CFBundleIcons</key>
    <dict>
        <key>CFBundlePrimaryIcon</key>
        <dict>
            <key>CFBundleIconFiles</key>
            <array>
                <string>AppIcon</string>
            </array>
        </dict>
    </dict>
</dict>
</plist>
